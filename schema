-- BinMaster Article Survey
-- Paste this into Supabase → SQL Editor and click Run

create table if not exists survey_responses (
  id            uuid primary key default gen_random_uuid(),
  article_title text not null,
  rating        text not null check (rating in ('awesome', 'good', 'ok', 'poor')),
  clicked_sales boolean not null default false,
  time_on_page  integer not null,   -- seconds from page load to vote
  responded_at  timestamptz not null default now()
);

-- Anonymous users can insert votes
alter table survey_responses enable row level security;

create policy "anyone can vote"
  on survey_responses for insert to anon
  with check (true);

create policy "authenticated can read"
  on survey_responses for select to authenticated
  using (true);
